{
	"name": "pennywise",
	"private": true,
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite build && vite preview --host",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "biome check && pnpm run check",
		"lint:fix": "biome check --write && pnpm run check",
		"prisma": "prisma format && prisma db push"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.3",
		"@internationalized/date": "^3.8.2",
		"@lucide/svelte": "0.515.0",
		"@sveltejs/adapter-node": "5.2.13",
		"@sveltejs/kit": "2.27.0",
		"@sveltejs/vite-plugin-svelte": "6.1.0",
		"@tailwindcss/vite": "4.1.11",
		"@types/node": "^24.2.0",
		"bits-ui": "^2.9.1",
		"clsx": "2.1.1",
		"husky": "9.1.7",
		"lint-staged": "16.1.4",
		"prisma": "6.13.0",
		"svelte": "5.37.3",
		"svelte-check": "4.3.1",
		"tailwind-merge": "3.3.1",
		"tailwind-variants": "1.0.0",
		"tailwindcss": "4.1.11",
		"tw-animate-css": "1.3.6",
		"typescript": "5.9.2",
		"vite": "7.0.6"
	},
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@prisma/client",
			"@prisma/engines",
			"@tailwindcss/oxide",
			"esbuild",
			"prisma"
		]
	},
	"dependencies": {
		"@prisma/client": "6.13.0",
		"jose": "6.0.12",
		"lucide-svelte": "^0.536.0"
	}
}
