{
	"name": "pennywise",
	"private": true,
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"dev": "svelte-kit sync && vite dev --host",
		"build": "npm run lint && vite build",
		"preview": "npm run build && vite preview --host",
		"prepare": "husky && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "npm run check && prettier --check . && eslint .",
		"lint:fix": "npm run check && prettier --write . && eslint --fix .",
		"prisma": "prisma format && prisma db push",
		"prisma-generate": "prisma format && prisma generate"
	},
	"lint-staged": {
		"*.{js,ts,.svelte}": "npm run lint"
	},
	"devDependencies": {
		"@eslint/compat": "1.3.1",
		"@eslint/js": "9.31.0",
		"@lucide/svelte": "0.525.0",
		"@sveltejs/adapter-node": "5.2.13",
		"@sveltejs/kit": "2.25.1",
		"@sveltejs/vite-plugin-svelte": "6.1.0",
		"@tailwindcss/vite": "4.1.11",
		"clsx": "2.1.1",
		"eslint": "9.31.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.11.0",
		"globals": "16.3.0",
		"husky": "9.1.7",
		"lint-staged": "16.1.2",
		"mode-watcher": "1.1.0",
		"prettier": "3.6.2",
		"prettier-plugin-svelte": "3.4.0",
		"prettier-plugin-tailwindcss": "0.6.14",
		"prisma": "6.12.0",
		"svelte": "5.36.12",
		"svelte-check": "4.3.0",
		"svelte-sonner": "1.0.5",
		"tailwind-merge": "3.3.1",
		"tailwind-variants": "1.0.0",
		"tailwindcss": "4.1.11",
		"tw-animate-css": "1.3.5",
		"typescript": "5.8.3",
		"typescript-eslint": "8.37.0",
		"vite": "7.0.5"
	},
	"dependencies": {
		"@prisma/client": "6.12.0"
	}
}
