{
	"name": "pennywise",
	"private": true,
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite build && vite preview --host",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "biome check && pnpm run check",
		"lint:fix": "biome check --write && pnpm run check"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.3",
		"@lucide/svelte": "0.536.0",
		"@sveltejs/adapter-node": "5.2.13",
		"@sveltejs/kit": "2.27.0",
		"@sveltejs/vite-plugin-svelte": "6.1.0",
		"@tailwindcss/vite": "4.1.11",
		"clsx": "2.1.1",
		"husky": "9.1.7",
		"lint-staged": "16.1.2",
		"svelte": "5.37.2",
		"svelte-check": "4.3.0",
		"tailwind-merge": "3.3.1",
		"tailwind-variants": "2.1.0",
		"tailwindcss": "4.1.11",
		"tw-animate-css": "1.3.6",
		"typescript": "5.9.2",
		"vite": "7.0.6"
	},
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
